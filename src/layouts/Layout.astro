---
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { 
  title = "Casa de Castro Alves | Memória, Arte e Poesia", 
  description = "A Casa de Castro Alves é um espaço de cultura e resistência em Salvador, Bahia. Dedicado ao diálogo entre a poesia e as artes, oferece galeria de arte contemporânea, eventos e o Movimento Irun." 
} = Astro.props;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/05_icone_amarelo.png" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="keywords" content="Casa de Castro Alves, Castro Alves, Salvador, Santo Antonio Alem do Carmo, Centro Historico, Poesia, Movimento Irun, Aluguel de Espaco Salvador, Eventos Salvador" />
    <meta name="author" content="Casa de Castro Alves" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://casadecastroalves.com.br/" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="/01_logo_amarelo_ig.png" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content="https://casadecastroalves.com.br/" />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content="/01_logo_amarelo_ig.png" />

    <!-- Google Fonts Preconnect -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  </head>
  <body>
    <!-- Top-level Navigation -->
    <Navigation />

    <!-- Main Content Area -->
    <main id="main-content">
      <slot />
    </main>

    <!-- Global Footer -->
    <Footer />
  </body>
</html>

<style>
  body {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    background-color: var(--color-creme);
  }

  main {
    flex-grow: 1;
    display: flex;
    flex-direction: column;
  }
</style>
