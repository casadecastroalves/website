---
import Layout from '../layouts/Layout.astro';

// Shows page for Casa de Castro Alves
---

<Layout title="Programação Cultural e Shows | Casa de Castro Alves" description="Confira os shows, espetáculos e apresentações musicais na Casa de Castro Alves. Destaque para o show de Curumin e o acervo histórico dos concertos do Movimento Irun." ogImage="/images/shows/movimento-irun-edicao-9-aqualtunes-mariella-santiago.jpg">
  <!-- Hero Section -->
  <section class="subpage-hero">
    <div class="subpage-hero-bg" style="background-image: url('/images/shows/movimento-irun-edicao-9-aqualtunes-mariella-santiago.jpg');"></div>
    <div class="subpage-hero-overlay"></div>
    <div class="container subpage-hero-content">
      <h1 class="subpage-hero-title">Programação de Shows</h1>
      <p class="subpage-hero-subtitle">Música e Performance</p>
    </div>
  </section>

  <!-- Featured Shows (Movimento Irun 11ª Edição & Curumin) -->
  <section class="featured-show-section">
    <div class="container">
      <!-- Duo iRê iRê - 11ª Edição -->
      <div class="featured-card" style="margin-bottom: var(--space-xl);">
        <div class="featured-image-wrapper" style="background-color: #111111; display: flex; align-items: center; justify-content: center;">
          <img src="/images/shows/MOVIMENTO-IRUN-11-EDICAO-7-DE-JUNHO-SENTE-O-TEMPO-PASSAR-DUO-IRE-IRE.png" alt="Cartaz Oficial do Show Sente o Tempo Passar - Duo iRê iRê" class="featured-show-img" style="object-fit: contain; max-height: 500px;" />
        </div>
        <div class="featured-details">
          <h2>Duo iRê iRê — Sente o Tempo Passar</h2>
          <p class="show-date">7 de Junho de 2026 • 19:00 — Movimento Irun 11ª Edição</p>
          
          <div style="margin-bottom: var(--space-md);">
            <a href="https://docs.google.com/forms/d/e/1FAIpQLSdYlaHZ_6jtI8SrXIyznc4ejZ9JRGsyC8JqBJ85dG9HoKNdhA/viewform" target="_blank" rel="noopener noreferrer" class="btn btn-primary">INSCREVA-SE</a>
          </div>

          <p class="show-description">
            O <strong>Duo iRê iRê</strong>, formado por <strong>Maíra & Ícaro Santiago</strong>, apresenta o show <em>“Sente o Tempo Passar”</em> na Casa de Castro Alves. Sob a temática <em>“Águas Nascentes: Tempo de Recomeços”</em>, a performance traz uma fusão sensível de ritmos, afeto e poesia.
          </p>
          <p class="show-info-text">
            A apresentação celebra o lançamento da 11ª Edição do Movimento Irun. A entrada é gratuita mediante inscrição prévia.
          </p>
        </div>
      </div>

      <!-- Featured Show (Curumin) -->
      <div class="featured-card">
        <div class="featured-image-wrapper">
          <img src="/images/shows/CURUMIN-MAIO-2026-819x1024.jpg" alt="Cartaz Oficial do Show de Curumin na Casa de Castro Alves" class="featured-show-img" />
        </div>
        <div class="featured-details">
          <h2>Curumin na Casa</h2>
          <p class="show-date">Maio de 2026 — Sessão Especial</p>

          <p class="show-description">
            O aclamado multi-instrumentista, cantor e produtor paulistano <strong>Curumin</strong> desembarca no Centro Histórico de Salvador para um show intimista e inesquecível no Jardim da Casa de Castro Alves. Unindo suas influências de samba, soul, funk clássico e hip-hop, o artista traz uma performance calorosa que sintoniza perfeitamente com a brisa da Baía de Todos os Santos.
          </p>
          <p class="show-info-text">
            Um encontro singular entre a rítmica paulista e a pulsação baiana em um dos espaços mais poéticos da cidade. Ingressos limitados para garantir o clima intimista e afetivo do evento.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Historical Shows Grid -->
  <section id="galeria-historica" class="past-shows-section">
    <div class="container">
      <div class="section-header text-center">
        <h2>Concertos e Apresentações Anteriores</h2>
        <p class="section-subtitle">Relembre as performances e artistas que já passaram pelo palco da Casa de Castro Alves ao longo do Movimento Irun.</p>
      </div>

      <div class="shows-grid">
        <!-- Show 11: Duo iRê iRê -->
        <a href="/movimento-irun/edicao-11" class="show-card card">
          <div class="card-img-wrapper">
            <img src="/images/edicoes/edicao-11/header/duo-ire-ire-sente-o-tempo-passar-movimento-irun-edicao-11-header.jpg" alt="Show do Duo iRê iRê" />
          </div>
          <div class="card-content">
            <span class="card-tag">11ª Edição</span>
            <h3>Duo iRê iRê</h3>
            <p class="card-date">Junho 2026</p>
            <p class="card-desc">Show de estreia "Sente O Tempo Passar" com uma fusão sensível de ritmos, afeto e poesia.</p>
          </div>
        </a>

        <!-- Show 10: Denise Correia -->
        <a href="/movimento-irun/edicao-10" class="show-card card">
          <div class="card-img-wrapper">
            <img src="/images/edicoes/edicao-10/header/denise-correia-black-tudo-movimento-irun-edicao-10-header.jpg" alt="Show de Denise Correia" />
          </div>
          <div class="card-content">
            <span class="card-tag">10ª Edição</span>
            <h3>Denise Correia</h3>
            <p class="card-date">Maio 2026</p>
            <p class="card-desc">Show “BLACK TUDO”, com Denise Correia e Banda Naveiadanêga, uma explosão de Afro Pop, samba rock e MPB.</p>
          </div>
        </a>

        <!-- Show 9: Mariella Santiago -->
        <a href="/movimento-irun/edicao-9" class="show-card card">
          <div class="card-img-wrapper">
            <img src="/images/edicoes/edicao-9/header/mariella-santiago-aqualtunes-movimento-irun-edicao-9-header.jpg" alt="Show de Mariella Santiago" />
          </div>
          <div class="card-content">
            <span class="card-tag">9ª Edição</span>
            <h3>Mariella Santiago</h3>
            <p class="card-date">Abril 2026</p>
            <p class="card-desc">Show imersivo <em>“Aqualtunes”</em>, com vocais processados em loops e arranjos afro-jazz contemporâneos.</p>
          </div>
        </a>

        <!-- Show 8: Yayá Muxima -->
        <a href="/movimento-irun/edicao-8" class="show-card card">
          <div class="card-img-wrapper">
            <img src="/images/edicoes/edicao-8/header/yaya-muxima-tambor-de-mulher-movimento-irun-edicao-8-header.jpg" alt="Show da Banda Yayá Muxima" />
          </div>
          <div class="card-content">
            <span class="card-tag">8ª Edição</span>
            <h3>Banda Yayá Muxima</h3>
            <p class="card-date">Março 2026</p>
            <p class="card-desc">Show <em>“Tambor de Mulher que sacode o Mundo”</em>, celebrando os 179 anos de nascimento do poeta Castro Alves.</p>
          </div>
        </a>

        <!-- Show 7: Ícaro Santiago & Eric Mazzone -->
        <a href="/movimento-irun/edicao-7" class="show-card card">
          <div class="card-img-wrapper">
            <img src="/images/edicoes/edicao-7/header/icaro-santiago-eric-mazzone-jangada-movimento-irun-edicao-7-header.jpg" alt="Show de Ícaro Santiago e Eric Mazzone" />
          </div>
          <div class="card-content">
            <span class="card-tag">7ª Edição</span>
            <h3>Ícaro Santiago & Éric Mazzone</h3>
            <p class="card-date">Janeiro 2026</p>
            <p class="card-desc">Show <em>“Jangada”</em>, uma fusão estética experimental entre sintetizadores, atabaques e jazz futurista.</p>
          </div>
        </a>

        <!-- Show 6: Cabuloso Trio -->
        <a href="/movimento-irun/edicao-6" class="show-card card">
          <div class="card-img-wrapper">
            <img src="/images/edicoes/edicao-6/header/cabuloso-trio-ocupacao-manifesto-movimento-irun-edicao-6-header.jpg" alt="Show do Cabuloso Trio" />
          </div>
          <div class="card-content">
            <span class="card-tag">6ª Edição</span>
            <h3>Cabuloso Trio</h3>
            <p class="card-date">Dezembro 2025</p>
            <p class="card-desc">Destaque da música instrumental e alternativa de Salvador em um encerramento repleto de convidados.</p>
          </div>
        </a>

        <!-- Show 5: Dão Black -->
        <a href="/movimento-irun/edicao-5" class="show-card card">
          <div class="card-img-wrapper">
            <img src="/images/edicoes/edicao-5/header/dao-black-sambadelic-movimento-irun-edicao-5-header.jpg" alt="Show de Dão Black" />
          </div>
          <div class="card-content">
            <span class="card-tag">5ª Edição</span>
            <h3>Dão Black</h3>
            <p class="card-date">Novembro 2025</p>
            <p class="card-desc">Dão Black apresenta o show Sambadelic, que revisita as matrizes e influências do samba brasileiro</p>
          </div>
        </a>

        <!-- Show 4: Tito Bahiense & Tiago Nunes -->
        <a href="/movimento-irun/edicao-4" class="show-card card">
          <div class="card-img-wrapper">
            <img src="/images/edicoes/edicao-4/header/tito-bahiense-tiago-nunes-ijexa-movimento-irun-edicao-4-header.jpg" alt="Show de Tito Bahiense e Tiago Nunes" />
          </div>
          <div class="card-content">
            <span class="card-tag">4ª Edição</span>
            <h3>Tito Bahiense</h3>
            <p class="card-date">Outubro 2025</p>
            <p class="card-desc">Celebração da beleza rítmica do Ijexá, com tambores e arranjos melódicos em homenagem a Oxum e Oxalá.</p>
          </div>
        </a>

        <!-- Show 3: Enio & Vírus -->
        <a href="/movimento-irun/edicao-3" class="show-card card">
          <div class="card-img-wrapper">
            <img src="/images/edicoes/edicao-3/header/enio-virus-encontros-hibridos-movimento-irun-edicao-3-header.jpg" alt="Show de Enio e Vírus" />
          </div>
          <div class="card-content">
            <span class="card-tag">3ª Edição</span>
            <h3>Enio & Vírus</h3>
            <p class="card-date">Setembro 2025</p>
            <p class="card-desc">Performance <em>“Encontros Híbridos”</em> com ritos poéticos sobre a infância e ancestralidade afrocentrada.</p>
          </div>
        </a>

        <!-- Show 2: Ayrá Soares & Ângelo Canja -->
        <a href="/movimento-irun/edicao-2" class="show-card card">
          <div class="card-img-wrapper">
            <img src="/images/edicoes/edicao-2/header/ayra-soares-angelo-canja-eletrosamba-movimento-irun-edicao-2-header.jpg" alt="Show de Ayrá Soares e Ângelo Canja" />
          </div>
          <div class="card-content">
            <span class="card-tag">2ª Edição</span>
            <h3>Ayrá Soares & Ângelo Canja</h3>
            <p class="card-date">Agosto 2025</p>
            <p class="card-desc">Show <em>“EletroSamba”</em> mesclando a voz ativista e percussiva de Ayrá com as texturas elétricas de Canja.</p>
          </div>
        </a>

        <!-- Show 1: Irma Ferreira -->
        <a href="/movimento-irun/edicao-1" class="show-card card">
          <div class="card-img-wrapper">
            <img src="/images/edicoes/edicao-1/header/irma-ferreira-cantos-de-orisa-movimento-irun-edicao-1-header.jpg" alt="Show de Irma Ferreira" />
          </div>
          <div class="card-content">
            <span class="card-tag">1ª Edição</span>
            <h3>Irma Ferreira</h3>
            <p class="card-date">Julho 2025</p>
            <p class="card-desc">Pocket show de lançamento <em>“Cantos de Òrìṣà”</em>, resgatando cantigas ancestrais e louvações acústicas.</p>
          </div>
        </a>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Featured Show Card */
  .featured-show-section {
    background-color: var(--color-creme);
  }

  .featured-card {
    background-color: var(--color-branco);
    border: 1px solid rgba(26, 26, 26, 0.08);
    display: grid;
    grid-template-columns: 1fr;
    box-shadow: 0 15px 35px rgba(26, 26, 26, 0.04);
  }

  @media (min-width: 992px) {
    .featured-card {
      grid-template-columns: 0.8fr 1.2fr;
    }
  }

  .featured-image-wrapper {
    overflow: hidden;
    position: relative;
    max-height: 500px;
  }

  .featured-show-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .featured-details {
    padding: var(--space-xl);
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .show-status-badge {
    align-self: flex-start;
    background-color: var(--color-amarelo-cca);
    color: var(--color-preto-editorial);
    font-family: var(--font-interface);
    font-size: 0.75rem;
    font-weight: bold;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 4px 12px;
    margin-bottom: var(--space-md);
  }

  .featured-details h2 {
    font-size: 2.5rem;
    margin-top: 0;
    margin-bottom: var(--space-sm);
    border: none;
    padding: 0;
  }

  .show-date, .show-price {
    font-family: var(--font-interface);
    font-weight: bold;
    font-size: 1rem;
    margin-bottom: var(--space-xs);
  }

  .show-price {
    display: inline-block;
    align-self: flex-start;
    background-color: var(--color-preto-editorial);
    color: var(--color-amarelo-cca);
    padding: 6px 12px;
    border-radius: 4px;
    font-size: 0.9rem;
    margin-bottom: var(--space-md);
  }

  .show-description {
    font-size: 1.1rem;
    color: var(--color-preto-editorial);
    line-height: 1.6;
    margin-bottom: var(--space-md);
  }

  .show-info-text {
    font-size: 0.95rem;
    color: var(--color-carvao);
    font-style: italic;
    margin-bottom: var(--space-lg);
  }

  .action-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
  }

  /* Past Shows Grid */
  .past-shows-section {
    background-color: var(--color-branco);
    border-top: 1px solid rgba(26, 26, 26, 0.05);
  }

  .shows-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
    margin-top: var(--space-xl);
  }

  @media (min-width: 576px) {
    .shows-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 992px) {
    .shows-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .show-card {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: 0;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
  }

  .card-img-wrapper {
    height: 350px;
    overflow: hidden;
    background-color: var(--color-cinza-claro);
    position: relative;
    border-bottom: 1px solid rgba(26, 26, 26, 0.05);
  }

  .card-img-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: var(--transition-smooth);
  }

  .show-card:hover .card-img-wrapper img {
    transform: scale(1.03);
  }

  .card-content {
    padding: var(--space-lg);
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  .card-tag {
    align-self: flex-start;
    font-family: var(--font-interface);
    font-size: 0.95rem; /* Slightly larger than date (0.85rem) */
    font-weight: bold;
    background-color: var(--color-preto-editorial);
    color: var(--color-amarelo-cca);
    padding: 6px 12px;
    border-radius: 4px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: var(--space-sm);
    display: inline-block;
  }

  .card-content h3 {
    font-size: 1.35rem;
    margin-top: 0;
    margin-bottom: var(--space-xs);
    border: none;
    padding: 0;
  }

  .card-date {
    font-family: var(--font-interface);
    font-size: 0.85rem;
    color: var(--color-carvao);
    margin-bottom: var(--space-md);
  }

  .card-desc {
    font-size: 0.95rem;
    color: var(--color-preto-editorial);
    line-height: 1.5;
    margin-bottom: 0;
  }
</style>
