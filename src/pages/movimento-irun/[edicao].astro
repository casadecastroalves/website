      show: "Tambor de Mulher",
      poster: "/images/shows/YAYA-MUXIMA-STORY-REEL-15-DE-MARCO-2026-8°-EDICAO-576x1024.png",
      youtube: "https://www.youtube.com/embed/zBGcQ43zOh8?si=Tc6UEdjmPY0ofbm6",
      descricao: "Com o lema 'Quando a poesia se faz aliança: 179 anos de Castro Alves', a oitava edição prestou homenagem ao nascimento do poeta republicano, abolicionista e patrono do casarão com uma programação inteiramente dedicada ao tambor feminino.",
      detalhes: [
        "Feira de Saberes e Sabores apresentando produtos ecológicos de comunidades tradicionais da Bahia.",
        "Gira de Saberes integrando guardiões da Universidade dos Povos debatendo a salvaguarda de sementes crioulas.",
        "Show espetáculo 'Tambor de Mulher que sacode o Mundo' da Banda Yayá Muxima, grupo composto exclusivamente por mulheres negras.",
        "Repertório repleto de canções autorais de ativismo feminista, clássicos de blocos afro (Ilê Aiyê, Olodum) e sambas tradicionais."
      ]
    },
    {
      num: 9,
      slug: "edicao-9",
      titulo: "9ª Edição — Show de Mariella Santiago",
      data: "26 de Abril de 2026",
      artista: "Mariella Santiago",
      show: "Aqualtunes",
      poster: "/images/shows/MOVIMENTO-IRUN-9-EDICAO-ABRIL-WEBSITE-1024x576.jpg",
      youtube: "https://www.youtube.com/embed/s9w44W419Co?si=pkRoavByGHpLUFFn",
      descricao: "Dedicada inteiramente aos povos originários e à cura ancestral da terra. O Jardim da Casa serviu de palco para o Toré da Aliança, ritual coletivo reunindo etnias em torno do bem viver e da soberania alimentar.",
      detalhes: [
        "Toré da Aliança: Ritual de resistência e espiritualidade com a presença de lideranças Pataxó, Tupinambá e Payayá.",
        "Oficina de Bordados pela Cidadania com o coletivo Linhas Bahia Axé, estimulando debates de direitos através da manufatura.",
        "Gira de Saberes 'Escola do Arco da Flecha e do Maracá' conduzida por Nádia Tupinambá e Cacique Ramon (Olivença).",
        "Concerto 'Aqualtunes' por Mariella Santiago com loops e vocais expandidos acompanhada pelas batidas de Ícaro Santiago."
      ]
    },
    {
      num: 10,
      slug: "edicao-10",
      titulo: "10ª Edição — Show de Denise Correia",
      data: "17 de Maio de 2026",
      artista: "Denise Correia",
      show: "Black Tudo",
      poster: "/images/shows/MOVIMENTO-IRUN-10-EDICAO-CASA-DE-CASTRO-ALVES-576x1024.png",
      youtube: "", // Sem vídeo listado
      descricao: "A décima edição marcou o encerramento do primeiro grande ciclo de encontros do Movimento Irun na Casa de Castro Alves. Reuniu ativistas, lideranças e artistas para celebrar a continuidade da aliança preta, indígena e popular e os portfólios sistematizados das comunidades.",
      detalhes: [
        "Apresentação de resultados e balanço geral das atividades formativas semanais do Ciclo Irun 2025/2026.",
        "Feira de encerramento Design Caboclo trazendo vestuário e biojoias produzidos durante as oficinas dialógicas.",
        "Roda de partilha sobre o protagonismo das comunidades tradicionais no fomento da economia comunitária e cidadania cultural.",
        "Show vibrante de Denise Correia cantando sucessos da música negra baiana, sambas clássicos e canções autorais."
      ]
    }
  ];

  return edicoesData.map((ed) => ({
    params: { edicao: ed.slug },
    props: { edicaoInfo: ed }
  }));
}

const { edicaoInfo } = Astro.props;
---

<Layout title={`${edicaoInfo.titulo} | Movimento Irun`} description={`Confira a programação e os registros da ${edicaoInfo.num}ª edição do Movimento Irun na Casa de Castro Alves. Convidado(a): ${edicaoInfo.artista}.`}>
  <!-- Header de Edição -->
  <section class="edicao-header">
    <div class="container text-center">
      <a href="/movimento-irun" class="back-link">← Voltar para o Movimento Irun</a>
      <span class="badge-edicao">{edicaoInfo.data}</span>
      <h1>Edição {edicaoInfo.num}</h1>
      <p class="subtitle-edicao">{edicaoInfo.show}</p>
    </div>
  </section>

  <!-- Detalhes da Edição -->
  <section class="edicao-details-section">
    <div class="container">
      <div class="details-grid">
        <!-- Poster Column -->
        <div class="poster-column">
          <div class="poster-wrapper shadow-premium">
            <img src={edicaoInfo.poster} alt={`Cartaz oficial - ${edicaoInfo.titulo}`} class="edicao-poster-img" />
            <div class="caption">Cartaz de divulgação do evento na Casa de Castro Alves.</div>
          </div>
        </div>

        <!-- Text Column -->
        <div class="text-column">
          <span class="section-badge">Memória do Encontro</span>
          <h2>Sobre esta Edição</h2>
          <p class="lead-text">{edicaoInfo.descricao}</p>

          <h3 class="program-title">Atividades e Destaques</h3>
          <ul class="highlights-list">
            {edicaoInfo.detalhes.map((det) => (
              <li>{det}</li>
            ))}
          </ul>

          <div class="artist-card">
            <h4>Artista Convidado(a)</h4>
            <p><strong>{edicaoInfo.artista}</strong></p>
            <p class="artist-helper">Espetáculo musical realizado no Jardim da Baía ao pôr do sol, celebrando as nossas matrizes culturais e a resistência popular.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Seção do Vídeo (se houver) -->
  {edicaoInfo.youtube && (
    <section class="video-section">
      <div class="container">
        <div class="section-header text-center">
          <h2>Registros em Vídeo</h2>
          <p class="section-subtitle">Assista à cobertura audiovisual e registros das apresentações desta edição.</p>
        </div>
        <div class="video-iframe-wrapper shadow-premium">
          <iframe 
            src={edicaoInfo.youtube} 
            width="100%" 
            height="500" 
            style="border:0;" 
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" 
            allowfullscreen
            title={`Vídeo registro - ${edicaoInfo.titulo}`}
          ></iframe>
        </div>
      </div>
    </section>
  )}
</Layout>

<style>
  /* Header Section */
  .edicao-header {
    background-color: var(--color-amarelo-cca);
    padding: var(--space-2xl) 0;
    border-bottom: 1px solid rgba(26, 26, 26, 0.05);
  }

  .back-link {
    display: inline-block;
    font-family: var(--font-interface);
    font-size: 0.85rem;
    font-weight: bold;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: var(--space-md);
    transition: var(--transition-fast);
  }

  .back-link:hover {
    color: var(--color-ouro);
    transform: translateX(-4px);
  }

  .badge-edicao {
    background-color: transparent;
    color: var(--color-preto-editorial);
    border: 1px solid var(--color-preto-editorial);
    padding: 4px 12px;
    font-family: var(--font-interface);
    font-size: 0.75rem;
    font-weight: bold;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    display: block;
    width: fit-content;
    margin: 0 auto var(--space-sm) auto;
  }

  .edicao-header h1 {
    font-size: 3rem;
    margin-bottom: var(--space-xs);
  }

  .subtitle-edicao {
    font-size: 1.25rem;
    color: var(--color-carvao);
    max-width: 600px;
    margin: 0 auto;
    font-style: italic;
  }

  /* Details section */
  .edicao-details-section {
    background-color: var(--color-creme);
  }

  .details-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
    align-items: flex-start;
  }

  @media (min-width: 992px) {
    .details-grid {
      grid-template-columns: 0.8fr 1.2fr;
    }
  }

  .poster-wrapper {
    background-color: var(--color-branco);
    padding: var(--space-sm);
    border: 1px solid rgba(26, 26, 26, 0.08);
    border-radius: 4px;
  }

  .edicao-poster-img {
    width: 100%;
    height: auto;
    max-height: 650px;
    object-fit: contain;
    display: block;
  }

  .caption {
    font-family: var(--font-interface);
    font-size: 0.75rem;
    color: var(--color-carvao);
    margin-top: var(--space-sm);
    font-style: italic;
  }

  .text-column h2 {
    font-size: 2.25rem;
    border: none;
    margin-top: var(--space-sm);
    margin-bottom: var(--space-md);
    padding: 0;
  }

  .section-badge {
    background-color: transparent;
    color: var(--color-ouro);
    border: 1px solid var(--color-ouro);
    padding: 4px 12px;
    font-family: var(--font-interface);
    font-size: 0.75rem;
    font-weight: bold;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    display: inline-block;
  }

  .lead-text {
    font-size: 1.2rem;
    line-height: 1.6;
    color: var(--color-preto-editorial);
    margin-bottom: var(--space-lg);
  }

  .program-title {
    font-size: 1.5rem;
    margin-top: var(--space-lg);
    margin-bottom: var(--space-md);
  }

  .highlights-list {
    list-style-type: none;
    margin-bottom: var(--space-xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .highlights-list li {
    font-size: 1.05rem;
    line-height: 1.5;
    position: relative;
    padding-left: var(--space-lg);
  }

  .highlights-list li::before {
    content: "•";
    color: var(--color-amarelo-cca);
    font-size: 1.5rem;
    line-height: 1;
    position: absolute;
    left: 0;
    top: -2px;
  }

  .artist-card {
    background-color: var(--color-branco);
    border: 1px solid rgba(26, 26, 26, 0.08);
    padding: var(--space-lg);
    border-left: 3px solid var(--color-ouro);
  }

  .artist-card h4 {
    font-family: var(--font-interface);
    font-size: 0.75rem;
    font-weight: bold;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-ouro);
    margin-bottom: var(--space-xs);
  }

  .artist-card p {
    font-size: 1.15rem;
    margin-bottom: var(--space-xs);
  }

  .artist-card .artist-helper {
    font-size: 0.9rem;
    color: var(--color-carvao);
    font-style: italic;
    margin-bottom: 0;
  }

  .shadow-premium {
    box-shadow: 0 15px 35px rgba(26, 26, 26, 0.06);
  }

  /* Video Section */
  .video-section {
    background-color: var(--color-branco);
    border-top: 1px solid rgba(26, 26, 26, 0.05);
  }

  .video-iframe-wrapper {
    background-color: var(--color-branco);
    padding: var(--space-sm);
    border: 1px solid rgba(26, 26, 26, 0.08);
    max-width: 900px;
    margin: var(--space-xl) auto 0 auto;
    border-radius: 4px;
  }

  .video-iframe-wrapper iframe {
    display: block;
    border-radius: 2px;
  }
</style>
