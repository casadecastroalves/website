<script is:inline>
  (function() {
    document.addEventListener('DOMContentLoaded', function() {
      // 1. Maratona Carousel Track
      var carousel = document.querySelector('.carousel-track');
      var btnLeft = document.querySelector('.carousel-arrow.prev');
      var btnRight = document.querySelector('.carousel-arrow.next');

      if (carousel && btnLeft && btnRight) {
        var getScrollAmount = function() {
          var firstCard = carousel.firstElementChild;
          if (!firstCard) return 300;
          return firstCard.offsetWidth + 16;
        };

        btnLeft.addEventListener('click', function() {
          carousel.scrollBy({ left: -getScrollAmount() * 2, behavior: 'smooth' });
        });

        btnRight.addEventListener('click', function() {
          carousel.scrollBy({ left: getScrollAmount() * 2, behavior: 'smooth' });
        });

        document.addEventListener('keydown', function(e) {
          // If the page has an active input/textarea, ignore keys
          if (document.activeElement && (document.activeElement.tagName === 'INPUT' || document.activeElement.tagName === 'TEXTAREA')) {
            return;
          }
          var rect = carousel.getBoundingClientRect();
          var inView = (rect.top < window.innerHeight && rect.bottom > 0);
          if (inView) {
            if (e.key === 'ArrowRight') {
              e.preventDefault();
              carousel.scrollBy({ left: getScrollAmount() * 2, behavior: 'smooth' });
            } else if (e.key === 'ArrowLeft') {
              e.preventDefault();
              carousel.scrollBy({ left: -getScrollAmount() * 2, behavior: 'smooth' });
            }
          }
        });

        // Mouse drag-scrollable on desktop
        var isDown = false;
        var startX;
        var scrollLeft;

        carousel.addEventListener('mousedown', function(e) {
          isDown = true;
          carousel.classList.add('dragging');
          startX = e.pageX - carousel.offsetLeft;
          scrollLeft = carousel.scrollLeft;
        });

        carousel.addEventListener('mouseleave', function() {
          isDown = false;
          carousel.classList.remove('dragging');
        });

        carousel.addEventListener('mouseup', function() {
          isDown = false;
          carousel.classList.remove('dragging');
        });

        carousel.addEventListener('mousemove', function(e) {
          if (!isDown) return;
          e.preventDefault();
          var x = e.pageX - carousel.offsetLeft;
          var walk = (x - startX) * 1.5; // scroll speed multiplier
          carousel.scrollLeft = scrollLeft - walk;
        });
      }

      // 2. Edition Poster/Cards Slideshow
      var edTrack = document.querySelector('.edition-slideshow-track');
      var edSlides = document.querySelectorAll('.edition-slide');
      var edPrevBtn = document.querySelector('.edition-nav-btn.prev-btn');
      var edNextBtn = document.querySelector('.edition-nav-btn.next-btn');
      var edDots = document.querySelectorAll('.edition-dot');

      if (edTrack && edSlides.length > 0) {
        var edIndex = 0;

        var updateEdSlider = function() {
          edTrack.style.transform = 'translateX(-' + (edIndex * 100) + '%)';
          edDots.forEach(function(dot, idx) {
            dot.classList.toggle('active', idx === edIndex);
          });
        };

        var nextEdSlide = function() {
          edIndex = (edIndex + 1) % edSlides.length;
          updateEdSlider();
        };

        var prevEdSlide = function() {
          edIndex = (edIndex - 1 + edSlides.length) % edSlides.length;
          updateEdSlider();
        };

        if (edPrevBtn) {
          edPrevBtn.addEventListener('click', prevEdSlide);
        }

        if (edNextBtn) {
          edNextBtn.addEventListener('click', nextEdSlide);
        }

        edDots.forEach(function(dot, idx) {
          dot.addEventListener('click', function() {
            edIndex = idx;
            updateEdSlider();
          });
        });

        // Keyboard arrow navigation for edition slideshow (when in view)
        document.addEventListener('keydown', function(e) {
          if (document.activeElement && (document.activeElement.tagName === 'INPUT' || document.activeElement.tagName === 'TEXTAREA')) {
            return;
          }
          var rect = edTrack.getBoundingClientRect();
          var inView = (rect.top < window.innerHeight && rect.bottom > 0);
          if (inView) {
            if (e.key === 'ArrowRight') {
              e.preventDefault();
              nextEdSlide();
            } else if (e.key === 'ArrowLeft') {
              e.preventDefault();
              prevEdSlide();
            }
          }
        });

        // Swipe support
        var touchStartX = 0;
        var isTouchDragging = false;

        edTrack.addEventListener('touchstart', function(e) {
          touchStartX = e.touches[0].clientX;
          isTouchDragging = true;
        }, { passive: true });

        edTrack.addEventListener('touchend', function(e) {
          if (!isTouchDragging) return;
          var touchEndX = e.changedTouches[0].clientX;
          var diffX = touchStartX - touchEndX;

          if (Math.abs(diffX) > 50) {
            if (diffX > 0) {
              nextEdSlide();
            } else {
              prevEdSlide();
            }
          }
          isTouchDragging = false;
        }, { passive: true });
      }
    });
  })();
</script>

