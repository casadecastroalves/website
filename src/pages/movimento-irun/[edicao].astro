</style>

<script>
  // Edition Slideshow Logic
  const tracks = document.querySelectorAll('.edition-slideshow-track');
  
  tracks.forEach(track => {
    const container = track.closest('.edition-slideshow');
    if (!container) return;
    
    const slides = container.querySelectorAll('.edition-slide');
    const dots = container.querySelectorAll('.edition-dot');
    const prevBtn = container.querySelector('.edition-nav-btn.prev-btn');
    const nextBtn = container.querySelector('.edition-nav-btn.next-btn');

    if (slides.length > 1) {
      let currentIndex = 0;
      let startX = 0;
      let isDragging = false;
      let currentTranslate = 0;
      let prevTranslate = 0;

      const updateSlider = () => {
        track.style.transform = `translateX(-${currentIndex * 100}%)`;
        dots.forEach((dot, index) => {
          dot.classList.toggle('active', index === currentIndex);
        });
        prevTranslate = currentIndex * -track.offsetWidth;
      };

      const nextSlide = () => {
        currentIndex = (currentIndex + 1) % slides.length;
        updateSlider();
      };

      const prevSlide = () => {
        currentIndex = (currentIndex - 1 + slides.length) % slides.length;
        updateSlider();
      };

      if (nextBtn) nextBtn.addEventListener('click', nextSlide);
      if (prevBtn) prevBtn.addEventListener('click', prevSlide);

      dots.forEach((dot, index) => {
        dot.addEventListener('click', () => {
          currentIndex = index;
          updateSlider();
        });
      });

      // Touch and Drag events
      track.addEventListener('touchstart', (e) => touchStart(e.touches[0].clientX));
      track.addEventListener('touchend', touchEnd);
      track.addEventListener('touchmove', (e) => touchMove(e.touches[0].clientX));

      track.addEventListener('mousedown', (e) => touchStart(e.clientX));
      track.addEventListener('mouseup', touchEnd);
      track.addEventListener('mouseleave', touchEnd);
      track.addEventListener('mousemove', (e) => touchMove(e.clientX));

      function touchStart(x) {
        isDragging = true;
        startX = x;
        track.style.transition = 'none';
      }

      function touchMove(x) {
        if (!isDragging) return;
        const currentPosition = x - startX;
        currentTranslate = prevTranslate + currentPosition;
        track.style.transform = `translateX(${currentTranslate}px)`;
      }

      function touchEnd() {
        if (!isDragging) return;
        isDragging = false;
        const movedBy = currentTranslate - prevTranslate;
        track.style.transition = 'transform 0.4s cubic-bezier(0.25, 1, 0.5, 1)';
        
        if (movedBy < -50 && currentIndex < slides.length - 1) currentIndex += 1;
        else if (movedBy > 50 && currentIndex > 0) currentIndex -= 1;
        else if (movedBy < -50 && currentIndex === slides.length - 1) currentIndex = 0; // wrap
        else if (movedBy > 50 && currentIndex === 0) currentIndex = slides.length - 1; // wrap
        
        updateSlider();
      }

      // Keyboard support
      document.addEventListener('keydown', (e) => {
        if (e.key === 'ArrowRight') nextSlide();
        if (e.key === 'ArrowLeft') prevSlide();
      });
      
      // Update sizes on resize
      window.addEventListener('resize', updateSlider);
    }
  });
</script>