  @media (max-width: 768px) {
    .page-nav-arrow {
      padding: var(--space-xs);
    }
    .page-nav-arrow.prev-page-arrow {
      left: var(--space-xs);
    }
    .page-nav-arrow.next-page-arrow {
      right: var(--space-xs);
    }
