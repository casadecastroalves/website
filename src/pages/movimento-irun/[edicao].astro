  return edicoesData.map((ed) => ({
    params: { edicao: ed.slug },
    props: {
      edicaoInfo: ed,
      allEdicoes: edicoesData
    }
  }));
}

const { edicaoInfo, allEdicoes } = Astro.props;

const currentIndex = allEdicoes.findIndex(e => e.num === edicaoInfo.num);
const prevEdition = currentIndex > 0 ? allEdicoes[currentIndex - 1] : null;
const nextEdition = currentIndex < allEdicoes.length - 1 ? allEdicoes[currentIndex + 1] : null;

const romanNumerals = ["", "I", "II", "III", "IV", "V", "VI", "VII", "VIII", "IX", "X", "XI"];
const romanKey = romanNumerals[edicaoInfo.num] || "";
const parsedData = (parsedEditions as any)[romanKey] || { desc: [], program: [] };
const descriptionParagraphs = parsedData.desc && parsedData.desc.length > 0 ? parsedData.desc : [edicaoInfo.descricao];
const programItems = parsedData.program && parsedData.program.length > 0 ? parsedData.program : edicaoInfo.detalhes;
const hasMainVideo = edicaoInfo.youtube && edicaoInfo.num !== 9 && edicaoInfo.num !== 10 && edicaoInfo.num !== 11;
const posters = Array.isArray((edicaoInfo as any).posters) 
  ? (edicaoInfo as any).posters 
  : (edicaoInfo.poster ? [edicaoInfo.poster] : []);
---

<Layout title={`${edicaoInfo.titulo} | Movimento Irun`} showSponsors={true} description={`Confira a programação e os registros da ${edicaoInfo.num}ª edição do Movimento Irun na Casa de Castro Alves. Convidado(a): ${edicaoInfo.artista}.`} ogImage={edicaoInfo.banner || edicaoInfo.poster}>
  <!-- Header de Edição (Standardized Subpage Hero with Parallax) -->
  <section class="subpage-hero" style="position: relative;">
    <div class="subpage-hero-bg" style={`background-image: url('${edicaoInfo.banner || edicaoInfo.poster}');`}></div>
    <div class="subpage-hero-overlay"></div>
    
    {prevEdition && (
      <a href={`/movimento-irun/${prevEdition.slug}`} class="page-nav-arrow prev-page-arrow" aria-label="Edição Anterior">
        <svg viewBox="0 0 24 24" width="36" height="36"><path fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" d="M15 18l-6-6 6-6"/></svg>
      </a>
    )}
    {nextEdition && (
      <a href={`/movimento-irun/${nextEdition.slug}`} class="page-nav-arrow next-page-arrow" aria-label="Próxima Edição">
        <svg viewBox="0 0 24 24" width="36" height="36"><path fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" d="M9 18l6-6-6-6"/></svg>
      </a>
    )}

    <div class="container subpage-hero-content">
      <h1 class="subpage-hero-title">Edição {edicaoInfo.num}</h1>
      <p class="header-show-title">{edicaoInfo.show}</p>
      <p class="header-artist-name">{edicaoInfo.artista}</p>
      <div style="margin-top: 2rem;">
        <span class="badge-edicao-dark">{edicaoInfo.data}</span>
      </div>
    </div>
  </section>

  <!-- Detalhes da Edição -->
  <section class="edicao-details-section">
    <div class="container">
      <div class="details-grid">
        <!-- Poster Column -->
        <div class="poster-column">
          {posters.length > 1 ? (
            <div class="edition-slideshow shadow-premium">
              <div class="edition-slideshow-track-wrapper">
                <div class="edition-slideshow-track">
                  {posters.map((post, idx) => (
                    <div class="edition-slide">
                      <img src={post} alt={`Cartaz oficial ${idx + 1} - ${edicaoInfo.titulo}`} class="edicao-poster-img-contain" />
                    </div>
                  ))}
                </div>
              </div>
              
              <!-- Navigation Controls -->
              <button class="edition-nav-btn prev-btn" aria-label="Card anterior">
                <svg viewBox="0 0 24 24" width="20" height="20"><path fill="currentColor" d="M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12z"/></svg>
              </button>
              <button class="edition-nav-btn next-btn" aria-label="Próximo card">
                <svg viewBox="0 0 24 24" width="20" height="20"><path fill="currentColor" d="M10 6L8.59 7.41 13.17 12l-4.58 4.59L10 18l6-6z"/></svg>
              </button>
              
              <!-- Dots Indicator -->
              <div class="edition-slideshow-dots">
                {posters.map((_, idx) => (
                  <button class={`edition-dot ${idx === 0 ? 'active' : ''}`} aria-label={`Ir para card ${idx + 1}`}></button>
                ))}
              </div>
              
              <div class="caption">Card de divulgação oficial (navegue pelas setas ou arraste para ver mais).</div>
            </div>
          ) : (
            <div class="poster-wrapper shadow-premium">
              <img src={edicaoInfo.poster} alt={`Cartaz oficial - ${edicaoInfo.titulo}`} class="edicao-poster-img-contain" />
