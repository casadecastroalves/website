---
import Layout from '../../layouts/Layout.astro';

const edicoes = [
  {
    num: 1,
    data: "13 de Julho de 2025",
    artista: "Irma Ferreira",
    show: "Cantos de Òrìṣà",
    desc: "Lançamento oficial com ritual Bantu Indígena Caxuté e abertura da Exposição.",
    slug: "edicao-1",
    img: "/images/edicoes/edicao-1/header/irma-ferreira-cantos-de-orisa-movimento-irun-edicao-1-header.jpg"
  },
  {
    num: 2,
    data: "17 de Agosto de 2025",
    artista: "Ayrá Soares & Ângelo Canja",
    show: "EletroSamba",
    desc: "Parceria com o coletivo feminista Tamo Juntas e diálogo sobre resistência cotidiana.",
    slug: "edicao-2",
    img: "/images/edicoes/edicao-2/header/ayra-soares-angelo-canja-eletrosamba-movimento-irun-edicao-2-header.jpg"
  },
  {
    num: 3,
    data: "28 de Setembro de 2025",
    artista: "Enio & Vírus",
    show: "Encontros Híbridos",
    desc: "Edição voltada ao tema 'Viva os Santos Meninos', resgatando a potência da infância.",
    slug: "edicao-3",
    img: "/images/edicoes/edicao-3/header/enio-virus-encontros-hibridos-movimento-irun-edicao-3-header.jpg"
  },
  {
    num: 4,
    data: "26 de Outubro de 2025",
    artista: "Tito Bahiense",
    show: "Ijexá",
    desc: "Imersão na clave e na espiritualidade do ritmo Ijexá, com atabaques e Roda de Conversa.",
    slug: "edicao-4",
    img: "/images/edicoes/edicao-4/header/tito-bahiense-tiago-nunes-ijexa-movimento-irun-edicao-4-header.jpg"
  },
  {
    num: 5,
    data: "16 de Novembro de 2025",
    artista: "Dão Black",
    show: "Sambadelic",
    desc: "Discotecagem de André Oliveira e o show Sambadelic resgatando as matrizes do samba.",
    slug: "edicao-5",
    img: "/images/edicoes/edicao-5/header/dao-black-sambadelic-movimento-irun-edicao-5-header.jpg"
  },
  {
    num: 6,
    data: "21 de Dezembro de 2025",
    artista: "Cabuloso Trio",
    show: "Ocupação Manifesto",
    desc: "Toré dos Tupinambás, Feira de Saberes e Sabores e a Universidade dos Povos.",
    slug: "edicao-6",
    img: "/images/edicoes/edicao-6/header/cabuloso-trio-ocupacao-manifesto-movimento-irun-edicao-6-header.jpg"
  },
  {
    num: 7,
    data: "25 de Janeiro de 2026",
    artista: "Ícaro Santiago & Eric Mazzone",
    show: "Jangada",
    desc: "Ocupação Manifesto Teia dos Povos com Mestre Joelson Ferreira e concerto experimental.",
    slug: "edicao-7",
    img: "/images/edicoes/edicao-7/header/icaro-santiago-eric-mazzone-jangada-movimento-irun-edicao-7-header.jpg"
  },
  {
    num: 8,
    data: "15 de Março de 2026",
    artista: "Yayá Muxima & Banda",
    show: "Tambor de Mulher",
    desc: "Comemoração dos 179 anos de nascimento de Castro Alves com banda de mulheres negras.",
    slug: "edicao-8",
    img: "/images/edicoes/edicao-8/header/yaya-muxima-tambor-de-mulher-movimento-irun-edicao-8-header.jpg"
  },
  {
    num: 9,
    data: "26 de Abril de 2026",
    artista: "Mariella Santiago",
    show: "Aqualtunes",
    desc: "Show solo percussivo e loops dedicados aos povos originários e ao Toré da Aliança.",
    slug: "edicao-9",
    img: "/images/edicoes/edicao-9/header/mariella-santiago-aqualtunes-movimento-irun-edicao-9-header.jpg"
  },
  {
    num: 10,
    data: "17 de Maio de 2026",
    artista: "Denise Correia & Banda Naveiadanêga",
    show: "Black Tudo",
    desc: "Show “BLACK TUDO”, com Denise Correia e Banda Naveiadanêga, uma explosão de Afro Pop, samba rock e MPB.",
    slug: "edicao-10",
    img: "/images/edicoes/edicao-10/header/denise-correia-black-tudo-movimento-irun-edicao-10-header.jpg"
  },
  {
    num: 11,
    data: "07 de Junho de 2026",
    artista: "Maíra e Ícaro Santiago",
    show: "Águas Nascentes: Tempo de Recomeços",
    desc: "Reflexão sobre as águas, territórios e saberes tradicionais, com exposição, oficinas, gira de saberes e show de Maíra e Ícaro Santiago.",
    slug: "edicao-11",
    img: "/images/edicoes/edicao-11/header/duo-ire-ire-sente-o-tempo-passar-movimento-irun-edicao-11-header.jpg"
  },
  {
    num: "",
    data: "JULHO 25 A JUNHO 26",
    artista: "Movimento Irun",
    show: "11 Edições Completas",
    desc: "Todas as edições entre 2025 e 2026",
    slug: "11-edicoes",
    img: "/images/movimento_irun/TAMANDUA-TUPINAMBA-FOTO-LUCIANO-PAYAYA-BX.jpg"
  }
];
---

<Layout title="11 Edições Completas | Movimento Irun" description="Confira o registro histórico de todas as 11 edições do Movimento Irun na Casa de Castro Alves de Julho de 2025 a Junho de 2026." ogImage="/images/movimento_irun/TAMANDUA-TUPINAMBA-FOTO-LUCIANO-PAYAYA-BX.jpg">
  <!-- Hero Section -->
  <section class="subpage-hero">
    <div class="subpage-hero-bg" style="background-image: url('/images/movimento_irun/TAMANDUA-TUPINAMBA-FOTO-LUCIANO-PAYAYA-BX.jpg');"></div>
    <div class="subpage-hero-overlay"></div>
    <div class="container subpage-hero-content">
      <h1 class="subpage-hero-title">Movimento Irun</h1>
      <p class="subpage-hero-subtitle">11 Edições Completas</p>
      <div style="margin-top: 2rem;">
        <a 
          href="https://docs.google.com/forms/d/e/1FAIpQLSdYlaHZ_6jtI8SrXIyznc4ejZ9JRGsyC8JqBJ85dG9HoKNdhA/viewform" 
          target="_blank" 
          rel="noopener noreferrer" 
          class="btn btn-outline-amarelo"
        >
          INSCREVA-SE
        </a>
      </div>
    </div>
    <span class="header-credit">TAMANDUA TUPINAMBA por LUCIANO PAYAYÁ</span>
  </section>

  <!-- Edições Grid (Full 12 grid in 3 columns) -->
  <section class="edicoes-grid-section">
    <div class="container">
      <div class="section-header text-center">
        <span class="section-badge">Registro Histórico</span>
        <h2>Linha do Tempo das Edições</h2>
        <p class="section-subtitle">Abaixo estão listadas todas as edições realizadas do projeto cultural Movimento Irun entre 2025 e 2026.</p>
      </div>

      <div class="edicoes-grid">
        {edicoes.map((ed) => (
          <a href={ed.slug === '11-edicoes' ? '#' : `/movimento-irun/${ed.slug}`} class="edicao-card card">
            <div class="edicao-img-wrapper">
              <img src={ed.img} alt={ed.num ? `Poster oficial da ${ed.num}ª edição do Movimento Irun` : `Poster oficial do Movimento Irun - 11 Edições`} />
            </div>
            <div class="edicao-content">
              <span class="edicao-date">{ed.data}</span>
              <h3>{ed.num ? `Edição ${ed.num}: ` : ''}{ed.show}</h3>
              <p class="edicao-artist">Convidado(a): {ed.artista}</p>
              <p class="edicao-desc">{ed.desc}</p>
              <span class="edicao-link">{ed.slug === '11-edicoes' ? 'Você está aqui' : 'Ver detalhes da edição →'}</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Apoios e Logos Rodapé -->
  <section class="apoio-section">
    <div class="container text-center">
      <h3>Apoio e Fomento</h3>
      <p class="apoio-text">
        Este projeto foi contemplado nos Editais da Política Nacional Aldir Blanc Bahia e tem apoio financeiro do Governo do Estado da Bahia, por meio da Secretaria de Cultura do Estado via PNAB, direcionada pelo Ministério da Cultura - Governo Federal. A iniciativa é também contemplada pela Política Nacional Cultura Viva.
      </p>
      <div class="apoio-banner-wrapper">
        <img src="/REGUAS_PNAB_BA_CULTURA_VIVA.png" alt="Logos de apoio do Movimento Irun - Secult-BA, PNAB, Governo da Bahia, Ministério da Cultura, Cultura Viva" class="apoio-banner-img" />
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Button styles */
  .btn-outline-amarelo {
    border-color: var(--color-amarelo-cca);
    color: var(--color-amarelo-cca);
    background-color: transparent;
  }
  .btn-outline-amarelo:hover {
    background-color: var(--color-amarelo-cca);
    color: var(--color-preto-editorial);
    border-color: var(--color-amarelo-cca);
  }

  /* Grid styles scoped to this page */
  .edicoes-grid-section {
    background-color: var(--color-creme);
    padding: var(--space-2xl) 0;
  }

  .edicoes-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
    margin-top: var(--space-xl);
  }

  @media (min-width: 768px) {
    .edicoes-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .edicoes-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .edicao-card {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: 0;
    overflow: hidden;
    background-color: var(--color-branco);
    border: 1px solid rgba(26, 26, 26, 0.08);
    border-radius: 4px;
    text-decoration: none;
    color: inherit;
    transition: transform 0.2s ease-in-out, box-shadow 0.2s ease-in-out;
  }

  .edicao-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
  }

  .edicao-img-wrapper {
    aspect-ratio: 16 / 9;
    width: 100%;
    overflow: hidden;
    background-color: var(--color-cinza-claro);
  }

  .edicao-img-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .edicao-content {
    padding: var(--space-md);
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  .edicao-date {
    font-size: var(--font-xs);
    font-family: var(--font-mono);
    color: var(--color-cinza-escuro);
    text-transform: uppercase;
    margin-bottom: var(--space-xs);
  }

  .edicao-content h3 {
    font-family: var(--font-serif);
    font-size: var(--font-lg);
    line-height: 1.3;
    margin-bottom: var(--space-xs);
    color: var(--color-preto-editorial);
  }

  .edicao-artist {
    font-size: var(--font-sm);
    font-weight: 600;
    color: var(--color-ouro);
    margin-bottom: var(--space-sm);
  }

  .edicao-desc {
    font-size: var(--font-sm);
    line-height: 1.5;
    color: var(--color-cinza-escuro);
    margin-bottom: var(--space-md);
    flex-grow: 1;
  }

  .edicao-link {
    font-size: var(--font-sm);
    font-weight: 600;
    color: var(--color-ouro);
    display: inline-block;
    transition: var(--transition-fast);
  }

  .edicao-card:hover .edicao-link {
    color: var(--color-amarelo-cca);
  }

  /* Support Section scoped */
  .apoio-section {
    background-color: var(--color-branco);
    padding: var(--space-xl) 0;
    border-top: 1px solid rgba(26, 26, 26, 0.05);
  }

  .apoio-text {
    max-width: 800px;
    margin: 0 auto var(--space-lg);
    font-size: var(--font-sm);
    line-height: 1.6;
    color: var(--color-cinza-escuro);
  }

  .apoio-banner-wrapper {
    max-width: 1000px;
    margin: 0 auto;
  }

  .apoio-banner-img {
    width: 100%;
    height: auto;
    object-fit: contain;
  }
</style>
