  <script>
    // Client-side video gallery interactive switcher
    const videoItems = document.querySelectorAll('.video-item');
    const mainPlayer = document.getElementById('main-gallery-player');
    const playerBadge = document.getElementById('player-video-badge');
    const playerTitle = document.getElementById('player-video-title');
    const playerDesc = document.getElementById('player-video-desc');

    videoItems.forEach(item => {
      item.addEventListener('click', () => {
        // Remove active class from all items
        videoItems.forEach(el => el.classList.remove('active'));
        
        // Add active class to clicked item
        item.classList.add('active');

        // Get video details
        const videoId = item.getAttribute('data-id');
        const badge = item.getAttribute('data-badge');
        const title = item.getAttribute('data-title');
        const desc = item.getAttribute('data-desc');

        // Update main player
        if (mainPlayer && videoId) {
          mainPlayer.src = `https://www.youtube.com/embed/${videoId}?autoplay=1&enablejsapi=1&rel=0`;
        }

        // Update text metadata
        if (playerBadge) playerBadge.textContent = badge;
        if (playerTitle) playerTitle.textContent = title;
        if (playerDesc) playerDesc.textContent = desc;
      });
    });
  </script>

