  <!-- Client-side script for interactive Showroom, Carousel and Premium Lightbox -->
  <script>
    // Global Lightbox State
    interface LightboxItem {
      src: string;
      titulo: string;
      tecnica: string;
      detalhes: string;
      projeto?: string | null;
      artista?: string;
      instagram?: string;
    }

    // Parse designers list from the hidden data element
    const designersDataEl = document.getElementById('designers-data');
    const designersList = JSON.parse(designersDataEl ? designersDataEl.getAttribute('data-json') || '[]' : '[]');

    // Build the flat array of all showroom works for global slideshow
    const allShowroomObras: LightboxItem[] = [];
    designersList.forEach((designer: any) => {
      designer.obras.forEach((obra: any) => {
        allShowroomObras.push({
          src: obra.src,
          titulo: obra.titulo,
          tecnica: obra.tecnica,
          detalhes: obra.detalhes,
          projeto: designer.projeto,
          artista: designer.artista,
          instagram: designer.instagram
        });
      });
    });

    let activeObras: LightboxItem[] = allShowroomObras; // Default to all works flat list
    let activeIndex = 0;

    const lightbox = document.getElementById('premium-lightbox');
    const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement | null;
    const lightboxTitle = document.getElementById('lightbox-title');
    const lightboxAuthor = document.getElementById('lightbox-author');
    const lightboxInstagram = document.getElementById('lightbox-instagram') as HTMLAnchorElement | null;
    const lightboxInstagramHandle = document.getElementById('lightbox-instagram-handle');
    const lightboxDesc = document.getElementById('lightbox-desc');
    const lightboxImageContainer = document.querySelector('.lightbox-image-container');
    
    const closeBtn = document.getElementById('lightbox-close-btn');
    const prevBtnL = document.getElementById('lightbox-prev-btn');
    const nextBtnL = document.getElementById('lightbox-next-btn');

    function resetZoom() {
      if (lightboxImageContainer) {
        lightboxImageContainer.classList.remove('zoomed');
      }
      if (lightboxImg) {
        lightboxImg.style.transformOrigin = 'center center';
      }
    }

    function toggleZoom(e?: MouseEvent) {
      if (lightboxImageContainer && lightboxImg) {
        const isZoomed = lightboxImageContainer.classList.toggle('zoomed');
        if (isZoomed && e) {
          updateZoomOrigin(e);
        } else {
          lightboxImg.style.transformOrigin = 'center center';
        }
      }
    }

    function updateZoomOrigin(e: MouseEvent) {
      if (lightboxImageContainer && lightboxImg && lightboxImageContainer.classList.contains('zoomed')) {
        const rect = lightboxImageContainer.getBoundingClientRect();
        const x = e.clientX - rect.left;
        const y = e.clientY - rect.top;
        const xPercent = (x / rect.width) * 100;
        const yPercent = (y / rect.height) * 100;
        lightboxImg.style.transformOrigin = `${xPercent}% ${yPercent}%`;
      }
    }

    if (lightboxImg) {
      lightboxImg.addEventListener('click', (e) => toggleZoom(e));
    }

    if (lightboxImageContainer) {
      lightboxImageContainer.addEventListener('mousemove', (e) => {
        updateZoomOrigin(e as MouseEvent);
      });
      lightboxImageContainer.addEventListener('mouseleave', resetZoom);
    }

    function openLightbox(obrasList: LightboxItem[], index: number) {
      activeObras = obrasList;
      activeIndex = index;
      if (lightbox) {
        lightbox.style.display = 'flex';
        lightbox.setAttribute('aria-hidden', 'false');
        document.body.style.overflow = 'hidden'; // Disable scroll
        updateLightboxContent();
      }
    }

    function closeLightbox() {
      if (lightbox) {
        lightbox.style.display = 'none';
        lightbox.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = ''; // Restore scroll
        resetZoom();
      }
    }

    function updateLightboxContent() {
      resetZoom();
      if (activeObras.length > 0 && activeIndex >= 0 && activeIndex < activeObras.length) {
        const item = activeObras[activeIndex];
        if (lightboxImg) lightboxImg.src = item.src;
        
        // Hide title and description for showroom works
        if (lightboxTitle) lightboxTitle.style.display = 'none';
        if (lightboxDesc) lightboxDesc.style.display = 'none';
        
        // Format Designer — Marca
        if (lightboxAuthor) {
          if (item.artista && item.projeto) {
            lightboxAuthor.textContent = `${item.artista} — ${item.projeto}`;
          } else {
            lightboxAuthor.textContent = item.artista || item.projeto || '';
          }
        }

        // Instagram Link
        if (lightboxInstagram && item.instagram) {
          lightboxInstagram.style.display = 'inline-flex';
          lightboxInstagram.href = `https://instagram.com/${item.instagram.substring(1)}`;
          if (lightboxInstagramHandle) lightboxInstagramHandle.textContent = item.instagram;
        } else if (lightboxInstagram) {
          lightboxInstagram.style.display = 'none';
        }
      }
    }

    function nextImage() {
      if (activeObras.length > 0) {
        activeIndex = (activeIndex + 1) % activeObras.length;
        updateLightboxContent();
      }
    }

    function prevImage() {
      if (activeObras.length > 0) {
        activeIndex = (activeIndex - 1 + activeObras.length) % activeObras.length;
        updateLightboxContent();
      }
    }

    // Bind Lightbox Event Listeners
    if (closeBtn) closeBtn.addEventListener('click', closeLightbox);
    if (nextBtnL) nextBtnL.addEventListener('click', nextImage);
    if (prevBtnL) prevBtnL.addEventListener('click', prevImage);

    // Close Lightbox when clicking outside the frame (on large screens only)
    if (lightbox) {
      lightbox.addEventListener('click', (e) => {
        if (window.innerWidth > 768) {
          const target = e.target as HTMLElement;
          if (target === lightbox || target.classList.contains('lightbox-content-wrapper')) {
            closeLightbox();
          }
        }
      });
    }

    // Keyboard navigation
    window.addEventListener('keydown', (e) => {
      if (lightbox && lightbox.style.display === 'flex') {
        if (e.key === 'ArrowRight') nextImage();
        else if (e.key === 'ArrowLeft') prevImage();
        else if (e.key === 'Escape') closeLightbox();
      }
    });

    // Touch Swipe gestures for Lightbox
    let touchStartX = 0;
    let touchStartY = 0;

    if (lightbox) {
      lightbox.addEventListener('touchstart', (e) => {
        touchStartX = e.touches[0].clientX;
        touchStartY = e.touches[0].clientY;
      }, { passive: true });

      lightbox.addEventListener('touchend', (e) => {
        const touchEndX = e.changedTouches[0].clientX;
        const touchEndY = e.changedTouches[0].clientY;
        const diffX = touchEndX - touchStartX;
        const diffY = touchEndY - touchStartY;

        // Threshold of 50px for horizontal swipe
        if (Math.abs(diffX) > Math.abs(diffY) && Math.abs(diffX) > 50) {
          if (diffX > 0) {
            prevImage(); // Swipe right -> previous
          } else {
            nextImage(); // Swipe left -> next
          }
        }
      }, { passive: true });
    }

    // 1. Showroom Controller
    const selectorItems = document.querySelectorAll('.selector-item');
    const stageImg = document.getElementById('stage-img') as HTMLImageElement | null;
    const stageThumbs = document.getElementById('stage-thumbs');
    const stageSpecialty = document.getElementById('stage-specialty');
    const stageName = document.getElementById('stage-name');
    const stageInstagram = document.getElementById('stage-instagram') as HTMLAnchorElement | null;
    const stageQuote = document.getElementById('stage-quote');
    const showroomStage = document.getElementById('showroom-stage');

    // Function to bind click event to stage thumbnails
    function bindStageThumbEvents() {
      const thumbBtns = document.querySelectorAll('.stage-thumb-btn');
      thumbBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          thumbBtns.forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
          const newImgUrl = btn.getAttribute('data-img');
          const srcAttr = btn.getAttribute('data-img') || '';
          
          if (stageImg && newImgUrl) {
            stageImg.src = newImgUrl;
            // Set index of the active image to its global index
            const globalIdx = allShowroomObras.findIndex(o => o.src === srcAttr);
            stageImg.setAttribute('data-index', globalIdx.toString());
          }
        });
      });
    }

    // Click on Main Stage Image opens Lightbox
    if (stageImg) {
      stageImg.addEventListener('click', () => {
        const srcAttr = stageImg.src ? new URL(stageImg.src, window.location.href).pathname : '';
        // Find in allShowroomObras
        let globalIdx = allShowroomObras.findIndex(o => o.src === srcAttr || srcAttr.endsWith(o.src));
        if (globalIdx === -1) {
          // It's the cover photo. Let's create a temporary LightboxItem for it
          const coverItem: LightboxItem = {
            src: srcAttr,
            titulo: "Design Caboclo",
            tecnica: "Exposição",
            detalhes: "Mostra de design contemporâneo e tradições ancestrais da Bahia na Casa de Castro Alves.",
            artista: "Design Caboclo",
            projeto: null,
            instagram: "@casadecastroalves"
          };
          // Prepend to allShowroomObras for the slideshow
          openLightbox([coverItem, ...allShowroomObras], 0);
        } else {
          openLightbox(allShowroomObras, globalIdx);
        }
      });
    }

    function selectDesigner(item: Element) {
      selectorItems.forEach(el => el.classList.remove('active'));
      item.classList.add('active');

      // De-activate cover state
      if (showroomStage) {
        showroomStage.classList.remove('cover-active');
      }

      // Extract attributes
      const name = item.getAttribute('data-name') || '';
      const specialty = item.getAttribute('data-specialty') || '';
      const instagram = item.getAttribute('data-instagram') || '';
      const quote = item.getAttribute('data-quote') || '';
      const obrasRaw = item.getAttribute('data-obras') || '[]';
      const obras = JSON.parse(obrasRaw);

      // Update Text Info
      if (stageName) stageName.textContent = name;
      if (stageSpecialty) stageSpecialty.textContent = specialty;
      if (stageQuote) stageQuote.textContent = `"${quote}"`;
      
      if (stageInstagram) {
        if (instagram) {
          stageInstagram.style.display = 'inline-flex';
          stageInstagram.href = `https://instagram.com/${instagram.substring(1)}`;
          const span = stageInstagram.querySelector('span');
          if (span) span.textContent = instagram;
        } else {
          stageInstagram.style.display = 'none';
        }
      }

      // Update Stage Main Image
      if (stageImg && obras.length > 0) {
        stageImg.src = obras[0].src;
        stageImg.alt = obras[0].titulo;
        const globalIdx = allShowroomObras.findIndex(o => o.src === obras[0].src);
        stageImg.setAttribute('data-index', globalIdx.toString());
      }

      // Rebuild Stage Thumbnails
      if (stageThumbs) {
        if (obras.length > 0) {
          stageThumbs.style.display = 'flex';
          stageThumbs.innerHTML = obras.map((obra: any, idx: number) => `
            <button 
              class="stage-thumb-btn ${idx === 0 ? 'active' : ''}"
              data-img="${obra.src}"
              data-index="${idx}"
            >
              <img src="${obra.src}" alt="${obra.titulo}" />
            </button>
          `).join('');
          
          bindStageThumbEvents();
        } else {
          stageThumbs.style.display = 'none';
          stageThumbs.innerHTML = '';
        }
      }
    }

    selectorItems.forEach(item => {
      item.addEventListener('click', () => {
        selectDesigner(item);
      });
    });

    // Showroom Autoplay for Exhibitor Circles (especially on Mobile)
    let showroomAutoplayTimer: any = null;
    let userInteractedWithShowroom = false;

    function startShowroomAutoplay() {
      // Autoplay interval of 6 seconds
      showroomAutoplayTimer = setInterval(() => {
        if (userInteractedWithShowroom) return;
        
        const items = document.querySelectorAll('.selector-item');
        if (!items.length) return;
        
        const activeItem = document.querySelector('.selector-item.active');
        let nextIndex = 0;
        
        if (activeItem) {
          const currentIndex = Array.from(items).indexOf(activeItem);
          nextIndex = (currentIndex + 1) % items.length;
        }
        
        const nextItem = items[nextIndex] as HTMLButtonElement;
        if (nextItem) {
          selectDesigner(nextItem);
          // Scroll only the list container horizontally to center the circle, preventing page jumps
          const selectorList = document.querySelector('.selector-list');
          if (selectorList) {
            const listWidth = selectorList.clientWidth;
            const itemOffset = nextItem.getBoundingClientRect().left - selectorList.getBoundingClientRect().left + selectorList.scrollLeft;
            const itemWidth = nextItem.clientWidth;
            const scrollTarget = itemOffset - (listWidth / 2) + (itemWidth / 2);
            selectorList.scrollTo({
              left: scrollTarget,
              behavior: 'smooth'
            });
          }
        }
      }, 6000);
    }

    function stopShowroomAutoplay() {
      userInteractedWithShowroom = true;
      if (showroomAutoplayTimer) {
        clearInterval(showroomAutoplayTimer);
        showroomAutoplayTimer = null;
      }
    }

    // Start on load
    startShowroomAutoplay();

    // Listen for manual interactions to stop autoplay and let the user browse at their own pace
    const selectorListContainer = document.querySelector('.selector-list');
    if (selectorListContainer) {
      selectorListContainer.addEventListener('touchstart', stopShowroomAutoplay, { passive: true });
      selectorListContainer.addEventListener('mousedown', stopShowroomAutoplay, { passive: true });
    }

    // 2. Carousel Controller & Lightbox Binding for General Photos
    const track = document.getElementById('carousel-track');
    const trackWrapper = document.getElementById('carousel-track-wrapper');
    const prevBtn = document.getElementById('gallery-prev-btn');
    const nextBtn = document.getElementById('gallery-next-btn');
    const paginationText = document.getElementById('carousel-pagination-text');
    const slides = document.querySelectorAll('.carousel-slide');
    const totalSlides = slides.length;
    let currentIndex = 0;

    // Define the list of general photos as LightboxItem objects for the general gallery lightbox
    const generalObrasList: LightboxItem[] = Array.from(slides).map((slide, idx) => {
      const img = slide.querySelector('img');
      const srcVal = img ? img.getAttribute('src') || '' : '';
      return {
        src: srcVal,
        titulo: `Registros de Exposição — Showroom Design Caboclo`,
        tecnica: "Fotografia e Registro Social",
        detalhes: `Registro número ${idx + 1} capturando o showroom de moda sustentável, biojoias, ateliês e a vivência coletiva do Movimento Irun na Casa de Castro Alves.`,
        projeto: null,
        artista: "Movimento Irun",
        instagram: "@casadecastroalves"
      };
    });

    // Bind click to open general gallery image in Lightbox
    const generalImages = document.querySelectorAll('.carousel-slide img.clickable-lightbox');
    generalImages.forEach(img => {
      img.addEventListener('click', () => {
        const idxRaw = img.getAttribute('data-index') || '0';
        const index = parseInt(idxRaw);
        openLightbox(generalObrasList, index);
      });
    });

    function getSlideWidth() {
      if (slides.length > 0) {
        return slides[0].getBoundingClientRect().width + 24; // Width + gap
      }
      return 0;
    }

    function updateCarousel() {
      if (track) {
        const slideWidth = getSlideWidth();
        const offset = currentIndex * slideWidth;
        track.style.transform = `translate3d(-${offset}px, 0, 0)`;
      }
      if (paginationText) {
        paginationText.textContent = `${currentIndex + 1} / ${totalSlides}`;
      }
    }

    if (prevBtn && nextBtn && track && trackWrapper) {
      nextBtn.addEventListener('click', () => {
        if (currentIndex < totalSlides - 1) {
          currentIndex++;
        } else {
          currentIndex = 0; // Loop back
        }
        updateCarousel();
      });

      prevBtn.addEventListener('click', () => {
        if (currentIndex > 0) {
          currentIndex--;
        } else {
          currentIndex = totalSlides - 1; // Loop end
        }
        updateCarousel();
      });

      // Swipe support for homepage carousel
      let carouselStartX = 0;
      let carouselIsDragging = false;

      trackWrapper.addEventListener('touchstart', (e) => {
        carouselStartX = e.touches[0].clientX;
        carouselIsDragging = true;
      }, { passive: true });

      trackWrapper.addEventListener('touchend', (e) => {
        if (!carouselIsDragging) return;
        const endX = e.changedTouches[0].clientX;
        const diffX = endX - carouselStartX;
        if (Math.abs(diffX) > 50) {
          if (diffX > 0) {
            // Swipe right -> previous
            if (currentIndex > 0) {
              currentIndex--;
            } else {
              currentIndex = totalSlides - 1;
            }
          } else {
            // Swipe left -> next
            if (currentIndex < totalSlides - 1) {
              currentIndex++;
            } else {
              currentIndex = 0;
            }
          }
          updateCarousel();
        }
        carouselIsDragging = false;
      }, { passive: true });

      // Keyboard navigation for general gallery carousel when in view
      document.addEventListener('keydown', (e) => {
        // Ignore if lightbox is open
        if (lightbox && lightbox.style.display === 'flex') return;
        
        const rect = trackWrapper.getBoundingClientRect();
        const inView = (rect.top < window.innerHeight && rect.bottom > 0);
        if (inView) {
          if (e.key === 'ArrowRight') {
            e.preventDefault();
            if (currentIndex < totalSlides - 1) {
              currentIndex++;
            } else {
              currentIndex = 0;
            }
            updateCarousel();
          } else if (e.key === 'ArrowLeft') {
            e.preventDefault();
            if (currentIndex > 0) {
              currentIndex--;
            } else {
              currentIndex = totalSlides - 1;
            }
            updateCarousel();
          }
        }
      });

      window.addEventListener('resize', updateCarousel);
    }
  </script>




