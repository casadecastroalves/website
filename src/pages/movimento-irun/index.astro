    bottom: var(--space-md);
    right: var(--space-lg);
    font-family: var(--font-interface);
    font-size: 0.7rem;
    font-weight: bold;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(255, 255, 255, 0.65);
    z-index: 10;
  }

  @media (max-width: 768px) {
    .header-credit {
      right: var(--space-md);
      font-size: 0.65rem;
    }
  }

  .text-center-editorial {
    max-width: 960px;
    margin: 0 auto;
    text-align: center;
  }

  .editorial-text-block {
    text-align: left;
    margin-top: var(--space-md);
  }

  .text-column h2 {
    font-size: 2.25rem;
    border: none;
    margin-top: var(--space-sm);
    margin-bottom: var(--space-md);
    padding: 0;
  }

  .lead-text {
    font-size: 1.2rem;
    line-height: 1.6;
    color: var(--color-preto-editorial);
    margin-bottom: var(--space-md);
  }

  .shadow-premium {
    box-shadow: 0 15px 35px rgba(26, 26, 26, 0.06);
  }

  /* Inscrição Grid Section */
  .inscricao-section {
    background-color: var(--color-branco);
    border-top: 1px solid rgba(26, 26, 26, 0.05);
    border-bottom: 1px solid rgba(26, 26, 26, 0.05);
  }

  .inscricao-grid {
    display: grid;
